{
  "name": "@blueyerobotics/jszmq",
  "version": "0.3.0",
  "description": "Port of zeromq to Javascript over Web Socket transport",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./lib/index.js",
    "./package.json": "./package.json"
  },
  "types": "./lib/index.d.ts",
  "files": [
    "lib"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "prepare": "tsc",
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "clear": "rm -rf lib/ coverage/",
    "clear:all": "rm -rf node_modules/ npm-debug.log && npm run clear",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/BluEye-Robotics/jszmq"
  },
  "author": "",
  "license": "MPL-2.0",
  "bugs": {
    "url": "https://github.com/BluEye-Robotics/jszmq/issues"
  },
  "homepage": "https://github.com/BluEye-Robotics/jszmq#readme",
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/ws": "^8.5.10",
    "@vitest/coverage-v8": "^3",
    "typescript": "^6",
    "vitest": "^3"
  }
}
